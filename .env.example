# HRRR Threshold Tool — ingest worker configuration.
#
# Copy to `.env` (gitignored) and fill in. Every operational knob is an env var
# (spec 8.2); there are no secrets or paths in the repo. Defaults shown in
# comments are applied when the variable is unset.

# --- Cloudflare R2 (S3-compatible object storage) -------------------------
# Account-scoped S3 API endpoint, e.g. https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional key prefix inside the bucket (e.g. "hrrr/"). Default: "" (bucket root).
R2_PREFIX=

# --- NOAA HRRR source -----------------------------------------------------
# Default: https://noaa-hrrr-bdp-pds.s3.amazonaws.com  (spec 3.1)
NOAA_HRRR_BASE_URL=

# --- Storage override (testing) -------------------------------------------
# Leave blank for production (writes to the R2 bucket above). Set to a local
# path to run the WHOLE pipeline to a folder with no R2 — e.g. an end-to-end
# test before renting anything:  STORAGE_URL=/tmp/hrrr-out
STORAGE_URL=

# --- Ingest behavior ------------------------------------------------------
# Parallel forecast-hour workers (spec 2.1: two-worker parallel). Default: 2
INGEST_WORKERS=2
# Dask chunk size on the isobaric level axis (spec 3.3, mandatory). Default: 10
ISOBARIC_CHUNK=10
# Spatial (y-axis) tiles for the parcel engine. Higher = lower peak RSS per
# worker, slightly more time. Measured per worker: 1 tile=6.9GB/145s,
# 4=3.5GB/153s, 8=2.3GB/168s per forecast hour. Tune to (box_RAM / INGEST_WORKERS).
# Default: 8
PARCEL_TILES=8
# Scratch dir for downloaded/subset GRIB. Default: /tmp/hrrr-ingest
WORK_DIR=/tmp/hrrr-ingest
# Streaming fetch: when a forecast hour's GRIB isn't on NOAA yet (HTTP 404),
# poll every FETCH_POLL_SECONDS until it publishes, up to FETCH_MAX_WAIT_SECONDS,
# instead of failing. A worker then picks up each hour as NOAA publishes it
# (f00 ~init+55min; the tail later), so the cycle promotes shortly after its
# last hour lands. Defaults: 60s poll, 3600s (1h) max wait per hour.
FETCH_POLL_SECONDS=60
FETCH_MAX_WAIT_SECONDS=3600

# --- Logging (spec 2.5) ---------------------------------------------------
# Default: /var/log/hrrr-ingest/ingest.log
LOG_FILE=/var/log/hrrr-ingest/ingest.log
# DEBUG | INFO | WARNING | ERROR. Default: INFO
LOG_LEVEL=INFO

# --- Pushover failure notifications (spec 2.5; optional) ------------------
# Both must be set to enable notifications. Reuses existing Pushover app.
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=
